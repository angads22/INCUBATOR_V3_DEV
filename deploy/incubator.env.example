# Incubator v3 — Pi Zero 2W environment configuration
# Copy to /etc/incubator.env and edit for your setup.
# Sensitive values (passwords, API keys) should NOT be committed to git.

# --- Database ---
INCUBATOR_DB_URL=sqlite:///./database/incubator.db

# --- Auth ---
# Login is auto-enforced once an operator account is created during onboarding.
# Set this to true to require login even before any account exists.
INCUBATOR_REQUIRE_LOGIN=false
# INCUBATOR_SESSION_SECURE=true   # Mark session cookie Secure (enable behind HTTPS)
# INCUBATOR_SESSION_TTL=604800    # Session lifetime in seconds (default 7 days)

# --- GPIO pin assignments (BCM numbering) ---
# Defaults match the reference wiring in docs/PI_DEPLOY.md
GPIO_DHT_PIN=4
GPIO_HEATER_PIN=17
GPIO_FAN_PIN=27
GPIO_TURNER_PIN=22
GPIO_TURNER_DIR_PIN=23
GPIO_CANDLE_PIN=24
GPIO_ALARM_PIN=25
GPIO_LOCK_PIN=12
GPIO_DOOR_PIN=13
GPIO_SETUP_BUTTON_PIN=18
GPIO_RELAY_ACTIVE_LOW=true
# Set to true on dev machines without Pi hardware
GPIO_MOCK=false

# --- Onboarding / AP ---
INCUBATOR_AP_SSID_PREFIX=Incubator
INCUBATOR_AP_PASSWORD=setup1234
INCUBATOR_AP_IP=10.42.0.1
INCUBATOR_AUTO_HOTSPOT=true
INCUBATOR_SETUP_BUTTON_HOLD_SECONDS=4.0
# Wi-Fi regulatory country (ISO 3166-1 alpha-2). REQUIRED for the radio to
# transmit — on Bookworm the WLAN stays rfkill-blocked until this is set.
# Baked in at image-build time via build_image.sh --wifi-country.
INCUBATOR_WIFI_COUNTRY=US

# --- Camera ---
# picamera2 | opencv | mock
CAMERA_BACKEND=picamera2
CAMERA_IMAGE_DIR=/var/incubator/captures
CAMERA_RES_W=1920
CAMERA_RES_H=1080

# --- Vision model ---
# mock | tflite | api
VISION_BACKEND=mock
VISION_TFLITE_MODEL=/var/incubator/models/vision/model.tflite
# For remote vision API (GPT-4V, Claude Vision, Roboflow, custom):
# VISION_BACKEND=api
# VISION_API_URL=https://your-vision-server/analyze
# VISION_API_KEY=your-key-here
VISION_CONFIDENCE_THRESHOLD=0.65

# --- Sensor polling ---
SENSOR_POLL_INTERVAL=30
SENSOR_LOG_TO_DB=true

# --- Cloud / OTA (optional) ---
# Set ENABLE_CLOUD_SYNC=true and fill in DOMAIN_API_BASE + DEVICE_SHARED_SECRET
# to enable server heartbeats and over-the-air application updates.
ENABLE_CLOUD_SYNC=false
# DOMAIN_API_BASE=https://your-cloud-api.example.com
# DEVICE_SHARED_SECRET=change-me
HEARTBEAT_INTERVAL_SECONDS=300

# Device identifier — auto-generated by scripts/firstboot.sh on first boot.
# Format: PI-<serial_or_uuid>
# INCUBATOR_DEVICE_ID=PI-XXXXXXXXXXXXXXXX

# OTA poll interval in seconds (0 = managed by systemd incubator-ota.timer).
# Override to a positive value only if you want the Python app itself to poll.
OTA_POLL_INTERVAL_SECONDS=0
# Auto-update from GitHub Releases (app/ota). Set false to pin the version.
OTA_ENABLED=true

# --- Control daemon (Phase 3) ---
# When true, the safety-critical control loop runs as its own always-on
# service (incubator-control.service) so app updates never pause heater/turn
# control. NOTE: when enabling this, the web app must yield the heater/fan/
# turner/DHT pins to the daemon (integration step) to avoid GPIO contention.
CONTROL_DAEMON_ENABLED=false
CONTROL_INTERVAL=10
CONTROL_HYSTERESIS_C=0.4
TURN_INTERVAL_HOURS=3
# Humidity actuation: off (monitor only) | fan (vent to lower RH)
HUMIDITY_CONTROL_MODE=off
CONTROL_STATE_PATH=/run/incubator/control-state.json
CONTROL_COMMAND_PATH=/run/incubator/control-commands.jsonl

# --- Fleet MQTT bus (Phase 1) ---
# Point every unit at the hub's Mosquitto broker. Each unit publishes telemetry
# under <base>/<device_id>/{status,temp,humidity} and accepts commands on
# <base>/<device_id>/cmd. Disabled by default — a standalone unit ignores it.
MQTT_ENABLED=false
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=fleet
MQTT_TELEMETRY_INTERVAL=30
