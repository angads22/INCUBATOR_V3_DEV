# Incubator v3 — Pi Zero 2W environment configuration
# Copy to /etc/incubator.env and edit for your setup.
# Sensitive values (passwords, API keys) should NOT be committed to git.

# --- Database ---
INCUBATOR_DB_URL=sqlite:///./database/incubator.db

# --- Auth ---
INCUBATOR_REQUIRE_LOGIN=false
# INCUBATOR_SESSION_SECURE=true   # Enable when behind HTTPS

# --- GPIO pin assignments (BCM numbering) ---
# Defaults match the reference wiring in docs/PI_DEPLOY.md
GPIO_DHT_PIN=4
GPIO_HEATER_PIN=17
GPIO_FAN_PIN=27
GPIO_TURNER_PIN=22
GPIO_TURNER_DIR_PIN=23
GPIO_CANDLE_PIN=24
GPIO_ALARM_PIN=25
GPIO_LOCK_PIN=12
GPIO_DOOR_PIN=13
GPIO_SETUP_BUTTON_PIN=18
GPIO_RELAY_ACTIVE_LOW=true
# Set to true on dev machines without Pi hardware
GPIO_MOCK=false

# --- Onboarding / AP ---
INCUBATOR_AP_SSID_PREFIX=Incubator
INCUBATOR_AP_PASSWORD=setup1234
INCUBATOR_AP_IP=10.42.0.1
INCUBATOR_AUTO_HOTSPOT=true
INCUBATOR_SETUP_BUTTON_HOLD_SECONDS=4.0

# --- Camera ---
# picamera2 | opencv | mock
CAMERA_BACKEND=picamera2
CAMERA_IMAGE_DIR=/var/incubator/captures
CAMERA_RES_W=1920
CAMERA_RES_H=1080

# --- Vision model ---
# mock | tflite | api
VISION_BACKEND=mock
VISION_TFLITE_MODEL=/var/incubator/models/vision/model.tflite
# For remote vision API (GPT-4V, Claude Vision, Roboflow, custom):
# VISION_BACKEND=api
# VISION_API_URL=https://your-vision-server/analyze
# VISION_API_KEY=your-key-here
VISION_CONFIDENCE_THRESHOLD=0.65

# --- Sensor polling ---
SENSOR_POLL_INTERVAL=30
SENSOR_LOG_TO_DB=true

# --- Auto-update ---
# The Pi checks this repo at boot + weekly and self-updates when a new commit lands.
INCUBATOR_AUTO_UPDATE=true
INCUBATOR_REPO_URL=https://github.com/angads22/INCUBATOR_V3_DEV.git
INCUBATOR_UPDATE_BRANCH=main

# --- Cloud (optional) ---
ENABLE_CLOUD_SYNC=false
# DOMAIN_API_BASE=https://your-cloud-api.example.com
# DEVICE_SHARED_SECRET=change-me
HEARTBEAT_INTERVAL_SECONDS=300
