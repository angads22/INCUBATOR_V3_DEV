[Unit]
Description=Incubator v3 API (UNO Q)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/incubator-v3
EnvironmentFile=/etc/incubator-v3.env
ExecStart=/opt/incubator-v3/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
