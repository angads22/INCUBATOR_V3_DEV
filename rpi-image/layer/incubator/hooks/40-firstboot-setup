#!/bin/bash
# Hook 40 — Install the first-boot provisioning script and seed a skeleton
# environment file.  The real env file is finalised on first boot.
# Runs inside the image chroot during the bdebstrap customize phase.
set -euo pipefail

INSTALL_DIR="/opt/incubator"

# ---------------------------------------------------------------------------
# First-boot script (runs once on the device, before incubator.service)
# ---------------------------------------------------------------------------
cat > "${INSTALL_DIR}/scripts/firstboot.sh" << 'FB_EOF'
#!/usr/bin/env bash
# Incubator first-boot provisioning
# Runs once (guarded by /etc/incubator-firstboot.done) via
# incubator-firstboot.service before the main application starts.
set -euo pipefail

ENV_FILE="/etc/incubator.env"
DONE_MARKER="/etc/incubator-firstboot.done"
DEVICE_ID_FILE="/etc/incubator-device-id"
LOG_TAG="incubator-firstboot"

_log() { logger -t "${LOG_TAG}" "$*"; echo "[FIRSTBOOT] $*"; }

_log "Starting first-boot provisioning..."

# ── Generate device ID ─────────────────────────────────────────────────────
if [[ ! -f "${DEVICE_ID_FILE}" ]]; then
    # Prefer the Pi serial number; fall back to random UUID
    PI_SERIAL="$(grep -m1 Serial /proc/cpuinfo 2>/dev/null | awk '{print $NF}' || true)"
    if [[ -n "${PI_SERIAL}" && "${PI_SERIAL}" != "0000000000000000" ]]; then
        DEVICE_ID="PI-${PI_SERIAL^^}"
    else
        DEVICE_ID="PI-$(cat /proc/sys/kernel/random/uuid | tr -d '-' | cut -c1-16 | tr '[:lower:]' '[:upper:]')"
    fi
    echo "${DEVICE_ID}" > "${DEVICE_ID_FILE}"
    chmod 600 "${DEVICE_ID_FILE}"
    _log "Device ID: ${DEVICE_ID}"
fi

DEVICE_ID="$(cat "${DEVICE_ID_FILE}")"
SHORT_ID="${DEVICE_ID: -4}"

# ── Set unique hostname ────────────────────────────────────────────────────
BASE_HOSTNAME="$(cat /etc/hostname | tr -d '[:space:]')"
NEW_HOSTNAME="${BASE_HOSTNAME}-${SHORT_ID,,}"
echo "${NEW_HOSTNAME}" > /etc/hostname
hostnamectl set-hostname "${NEW_HOSTNAME}" 2>/dev/null || true
sed -i "s/127\.0\.1\.1.*/127.0.1.1\t${NEW_HOSTNAME}/" /etc/hosts 2>/dev/null || true
_log "Hostname: ${NEW_HOSTNAME}"

# ── Seed environment file ─────────────────────────────────────────────────
if [[ ! -f "${ENV_FILE}" ]]; then
    _log "Creating ${ENV_FILE}..."
    cp /opt/incubator/deploy/incubator.env.example "${ENV_FILE}"
    chmod 600 "${ENV_FILE}"
fi

# Always write a fresh AP password (safe to regenerate on first boot)
AP_PASS="$(dd if=/dev/urandom bs=9 count=1 2>/dev/null | base64 | tr -dc 'A-Za-z0-9' | cut -c1-12)"
sed -i "s|INCUBATOR_AP_PASSWORD=.*|INCUBATOR_AP_PASSWORD=${AP_PASS}|" "${ENV_FILE}"

# Inject Device ID into env file so the app and OTA agent can read it
if ! grep -q "^INCUBATOR_DEVICE_ID=" "${ENV_FILE}"; then
    echo "" >> "${ENV_FILE}"
    echo "# Auto-generated on first boot" >> "${ENV_FILE}"
    echo "INCUBATOR_DEVICE_ID=${DEVICE_ID}" >> "${ENV_FILE}"
fi

_log "AP password set (saved in ${ENV_FILE})"

# ── Expand root filesystem if needed ──────────────────────────────────────
if command -v raspi-config &>/dev/null; then
    raspi-config nonint do_expand_rootfs 2>/dev/null || true
fi

# ── Mark as done ──────────────────────────────────────────────────────────
touch "${DONE_MARKER}"
_log "First-boot provisioning complete."
_log "AP SSID:     Incubator-${SHORT_ID^^}"
_log "AP Password: ${AP_PASS}"
_log "Dashboard:   http://$(hostname -I | awk '{print $1}' 2>/dev/null || echo '10.42.0.1'):8000"
FB_EOF

chmod +x "${INSTALL_DIR}/scripts/firstboot.sh"

# ---------------------------------------------------------------------------
# Skeleton environment file in /etc (will be replaced on first boot)
# ---------------------------------------------------------------------------
cp "${INSTALL_DIR}/deploy/incubator.env.example" /etc/incubator.env
chmod 600 /etc/incubator.env

# ---------------------------------------------------------------------------
# Set the baked-in hostname (firstboot will append the short device ID)
# ---------------------------------------------------------------------------
HOSTNAME="${INCUBATOR_HOSTNAME:-incubator}"
echo "${HOSTNAME}" > /etc/hostname
grep -qE "^127\.0\.1\.1" /etc/hosts \
    && sed -i "s/^127\.0\.1\.1.*/127.0.1.1\t${HOSTNAME}/" /etc/hosts \
    || echo "127.0.1.1	${HOSTNAME}" >> /etc/hosts

echo "[incubator] First-boot setup complete (hostname=${HOSTNAME})"
